{
  "manifest_version": 3,
  "name": "SizeUp",
  "version": "0.1.0",
  "description": "Never check a size chart again.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://www.myntra.com/*",
    "https://www.amazon.in/*",
    "https://www.flipkart.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.myntra.com/*",
        "https://www.amazon.in/*",
        "https://www.flipkart.com/*"
      ],
      "js": [
        "utils/size-charts.js",
        "utils/storage.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
