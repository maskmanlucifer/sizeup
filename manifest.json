{
  "manifest_version": 3,
  "name": "SizeUp",
  "version": "1.0.0",
  "description": "Save your family's measurements once. SizeUp shows which sizes fit on Myntra, Amazon India & Flipkart.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "host_permissions": [
    "https://www.myntra.com/*",
    "https://www.amazon.in/*",
    "https://www.flipkart.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.myntra.com/*",
        "https://www.amazon.in/*",
        "https://www.flipkart.com/*"
      ],
      "js": [
        "utils/size-charts.js",
        "utils/storage.js",
        "content/platforms/myntra.js",
        "content/platforms/flipkart.js",
        "content/platforms/amazon.js",
        "content/ui.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
